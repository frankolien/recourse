# Recourse backend config. Testnet only (R7).
# Host port 5433 matches ops/docker-compose.yml (5432 is often taken locally).
DATABASE_URL=postgres://recourse:recourse@localhost:5433/recourse
ARC_RPC_URL=https://arc-testnet.drpc.org
# Contract addresses are read from this file (R3), never hardcoded.
DEPLOYMENTS_PATH=../deployments/arc-testnet.json
PORT=8080
INDEX_INTERVAL_SECS=15
# Demo-only endpoints (attestor bot etc.) are gated behind this (R6).
DEMO_MODE=true
# Attestor signing key for the demo attest/resolve endpoints. Testnet throwaway only
# (R7): never a mainnet key, never reused elsewhere. Must be the key for the escrow's
# attestor address (currently the deployer 0xD6c574461d96Ee708f58Fe553049aD4f48BB983A),
# or submitAttestation reverts with BadAttestor. Leave empty to keep the endpoints off.
ATTESTOR_PK=
# Content-addressed evidence blob store directory (keccak256-named blobs).
EVIDENCE_DIR=./evidence-store
# Admin bearer token guarding the privileged demo routes (attest/resolve). Fail-closed:
# leave empty and no one can trigger settlement. Set to a long random secret to enable
# operator use (e.g. `openssl rand -hex 32`). Never shipped to the mobile app.
ADMIN_API_KEY=
# Automated settlement worker. When true (and the attestor is enabled), a background job
# settles disputes that are due: attested, or past the escrow's resolveDelay. Off by
# default so it never surprise-settles a rehearsal. It never decides verdicts (R2/R4).
ATTESTOR_AUTO_RESOLVE=false
ATTESTOR_AUTO_RESOLVE_INTERVAL_SECS=30

# Sign in with Apple server configuration. The private key is downloaded once from
# Apple Developer and stored locally under backend/secrets, never in Git or the app.
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_CLIENT_ID=com.recourse.buyer
APPLE_PRIVATE_KEY_PATH=./secrets/AuthKey_KEY_ID.p8
# Sign in with Google. The OAuth 2.0 Web client id from Google Cloud Console; it is the
# aud of the ID tokens the web client obtains. Leave empty to keep Google sign-in off. The
# web needs the same value as NEXT_PUBLIC_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=
# Google iOS OAuth client id. iOS Google Sign-In mints ID tokens with the iOS client as
# aud, so set this so the same /api/auth/google endpoint accepts mobile logins too.
GOOGLE_IOS_CLIENT_ID=
# CORS: comma-separated browser origins allowed to call the API (e.g.
# https://recourse.app,http://localhost:3000). Empty = permissive (dev/demo only); set this
# in production to lock the API to the web app's origin.
CORS_ALLOWED_ORIGINS=
# Passkeys (WebAuthn). RP_ID is the bare domain the iOS app is associated with via its
# apple-app-site-association webcredentials entry (e.g. recourse.app); RP_ORIGIN is
# https://<RP_ID>. iOS passkeys need a real https domain (not localhost). Leave empty to
# keep the passkey endpoints off (503).
WEBAUTHN_RP_ID=
WEBAUTHN_RP_ORIGIN=
RUST_LOG=info,recourse_backend=debug
