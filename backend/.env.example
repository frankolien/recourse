# Recourse backend config. Testnet only (R7).
# Host port 5433 matches ops/docker-compose.yml (5432 is often taken locally).
DATABASE_URL=postgres://recourse:recourse@localhost:5433/recourse
ARC_RPC_URL=https://arc-testnet.drpc.org
# Contract addresses are read from this file (R3), never hardcoded.
DEPLOYMENTS_PATH=../deployments/arc-testnet.json
PORT=8080
INDEX_INTERVAL_SECS=15
# Demo-only endpoints (attestor bot etc.) are gated behind this (R6).
DEMO_MODE=true
# Attestor signing key for the demo attest/resolve endpoints. Testnet throwaway only
# (R7): never a mainnet key, never reused elsewhere. Must be the key for the escrow's
# attestor address (currently the deployer 0xD6c574461d96Ee708f58Fe553049aD4f48BB983A),
# or submitAttestation reverts with BadAttestor. Leave empty to keep the endpoints off.
ATTESTOR_PK=
# Content-addressed evidence blob store directory (keccak256-named blobs).
EVIDENCE_DIR=./evidence-store
# Admin bearer token guarding the privileged demo routes (attest/resolve). Fail-closed:
# leave empty and no one can trigger settlement. Set to a long random secret to enable
# operator use (e.g. `openssl rand -hex 32`). Never shipped to the mobile app.
ADMIN_API_KEY=
RUST_LOG=info,recourse_backend=debug
