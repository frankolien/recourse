# Copy to contracts/.env (forge auto-loads it) or export before deploying.
# Non-secret network facts also live in deployments/arc-config.json (verified from docs.arc.io).

ARC_RPC_URL=https://rpc.testnet.arc.network
RECOURSE_USDC=0x3600000000000000000000000000000000000000

# Testnet throwaway keys ONLY. Never reuse elsewhere; never commit real values (R7).
DEPLOYER_PK=
RECOURSE_ATTESTOR=
RECOURSE_TREASURY=

# Deploy tuning (optional; the script defaults to these).
RECOURSE_YIELD_FEE_BPS=1000
RECOURSE_RESOLVE_DELAY=60
# Mock-adapter path only: mints this USDC buffer to the adapter. On Arc, fund the
# adapter buffer with a separate USDC transfer after deploy (see handoff.md).
RECOURSE_ADAPTER_BUFFER=0
